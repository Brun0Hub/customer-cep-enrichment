   "source": [
    "import requests\n",
    "\n",
    "cep = \"20.720-295\"\n",
    "cep = cep.replace(\"-\",\"\").replace(\".\",\"\").replace(\" \",\"\")\n",
    "\n",
    "if len(cep) == 8:\n",
    "    link = f'https://viacep.com.br/ws/{cep}/json/'\n",
    "\n",
    "    request = requests.get(link)\n",
    "    dic_request = request.json()\n",
    "    print(dic_request)\n",
    "else:\n",
    "    print(\"Invalid CEP\")\n"
